[ext_resource type="Script" path="res://scripts/hud.gd" id="1_hud"]
[ext_resource type="Script" path="res://scripts/ui/digit_readout.gd" id="2_digits"]

; Sits under the reticle (layer 40) and the pause menu (50) so neither is ever obscured.
; Everything is anchored to a corner rather than centred: the middle of the screen belongs
; to the reticle and the interaction prompt.
;
; Both numbers are DigitReadouts, not Labels — see digit_readout.gd. A proportional font
; makes a live clock twitch sideways several times a second.

; A real radial vignette rather than a full-screen tint. A flat wash over the whole frame
; hides the panel the player is trying to repair at exactly the moment they most need to
; see it; darkening only the edges reads peripherally and leaves the centre playable.
[sub_resource type="Gradient" id="Gradient_vignette"]
offsets = PackedFloat32Array(0.45, 1)
colors = PackedColorArray(0.6, 0.03, 0.02, 0, 0.6, 0.03, 0.02, 1)

