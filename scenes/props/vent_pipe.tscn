[gd_scene load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/game/repair_point.gd" id="1_repair"]
[ext_resource type="PackedScene" uid="uid://dk6xbfpkj0ihj" path="res://3D-Models/CD_PipeBroken_v1.blend" id="2_broken"]
[ext_resource type="PackedScene" uid="uid://cgtrunexmdas4" path="res://3D-Models/CD_PipeDecor_v1.blend" id="3_intact"]

; The coolant line: the repair point you can READ from across the room.
;
; The two pipe models are the same fitting, one with a rupture bulge in it, which makes the
; permanent repair literally swap the broken pipe for a whole one. That is a much stronger
; read than the box-and-slab placeholder this replaces:
;
;   BROKEN     ruptured pipe, venting vapour
;   PATCHED    ruptured pipe still, with a band of tape over the split — the damage is
;              still visibly there, which is the entire point of the patch route
;   FIXED      the intact pipe
;
; Mount it standing on the FLOOR with local +Z pointing into the room; the elbows run out
; along +Z and the column sits back against the wall. Scaled 0.5 because the models are
; authored 7m tall and the engine room is 4m.

[sub_resource type="BoxMesh" id="BoxMesh_status"]
size = Vector3(0.14, 0.14, 0.04)

; Deliberately ugly: wrong colour, off-centre, too fat.
[sub_resource type="CylinderMesh" id="CylinderMesh_tape"]
top_radius = 0.19
bottom_radius = 0.185
height = 0.42
radial_segments = 12
rings = 1

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_tape"]
albedo_color = Color(0.62, 0.52, 0.2, 1)
roughness = 1.0

; A radial alpha falloff generated at load, so the puffs are soft blobs instead of the hard
; squares a bare QuadMesh gives.
[sub_resource type="Gradient" id="Gradient_puff"]
offsets = PackedFloat32Array(0, 0.35, 1)
colors = PackedColorArray(1, 1, 1, 1, 1, 1, 1, 0.55, 1, 1, 1, 0)

[sub_resource type="GradientTexture2D" id="GradientTexture2D_puff"]
gradient = SubResource("Gradient_puff")
width = 64
height = 64
fill = 1
fill_from = Vector2(0.5, 0.5)
fill_to = Vector2(1, 0.5)

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_puff"]
transparency = 1
shading_mode = 0
vertex_color_use_as_albedo = true
billboard_mode = 3
billboard_keep_scale = true
albedo_color = Color(0.85, 0.94, 1, 1)
albedo_texture = SubResource("GradientTexture2D_puff")

; The material goes ON THE MESH, not as a material_override on the particle node — an
; override there is ignored for the particle draw pass.
[sub_resource type="QuadMesh" id="QuadMesh_puff"]
material = SubResource("StandardMaterial3D_puff")
size = Vector2(1, 1)

[node name="VentPipe" type="Node3D"]
script = ExtResource("1_repair")
patch_text = "Tape the split"
fit_text = "Fit a new section"
broken_nodes = [NodePath("Vent")]
patched_nodes = [NodePath("Tape")]
fixed_nodes = [NodePath("Intact")]
damaged_nodes = [NodePath("Damaged")]

; Both models keep the StaticBody3D their `-col` suffix generated: unlike the crate this is
; static scenery, so its own collider is exactly what is wanted, and it is what the
; interaction ray hits before walking up the tree to this script. The two are coincident, so
; the pipe stays solid whichever one is currently shown.
[node name="Damaged" parent="." instance=ExtResource("2_broken")]
transform = Transform3D(0.5, 0, 0, 0, 0.5, 0, 0, 0, 0.5, 0, 0.25, 0)

[node name="Intact" parent="." instance=ExtResource("3_intact")]
transform = Transform3D(0.5, 0, 0, 0, 0.5, 0, 0, 0, 0.5, 0, 0.25, 0)

[node name="StatusLight" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.26, 1.72, 0.2)
mesh = SubResource("BoxMesh_status")

[node name="Tape" type="MeshInstance3D" parent="."]
transform = Transform3D(0.07, -0.996, 0, 0.996, 0.07, 0, 0, 0, 1, 0, 1.68, 0.14)
mesh = SubResource("CylinderMesh_tape")
surface_material_override/0 = SubResource("StandardMaterial3D_tape")

; Coolant flashing off as it hits vacuum pressure. Aimed up and only slightly out, so it
; reads from beside the pipe without filling the screen when you walk up to work on it.
[node name="Vent" type="CPUParticles3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.966, -0.259, 0, 0.259, 0.966, 0.05, 1.78, 0.22)
amount = 22
lifetime = 0.55
explosiveness = 0.05
randomness = 0.6
emission_shape = 1
emission_sphere_radius = 0.05
direction = Vector3(0, 1, 0)
spread = 16.0
gravity = Vector3(0, 0, 0)
initial_velocity_min = 0.5
initial_velocity_max = 1.1
damping_min = 1.4
damping_max = 2.2
scale_amount_min = 0.05
scale_amount_max = 0.14
color = Color(0.82, 0.93, 1, 0.6)
mesh = SubResource("QuadMesh_puff")
