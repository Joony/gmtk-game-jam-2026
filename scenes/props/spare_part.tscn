[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/interaction/interactable.gd" id="1_interactable"]

; A generic spare, identified by the `spare_parts` group rather than by name — any spare
; fits any panel. Scarcity does the work instead: there are fewer spares than there are
; faults in a run, so fitting one here means patching something else later.
;
; Deliberately a different colour and shape from the generic pickup crate: under pressure
; the player needs to spot a spare across a room, not read a label.

[sub_resource type="CylinderMesh" id="CylinderMesh_part"]
top_radius = 0.13
bottom_radius = 0.13
height = 0.44
radial_segments = 12
rings = 1

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_part"]
