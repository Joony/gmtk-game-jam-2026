shape = SubResource("BoxShape3D_pod")

; Where the player's BODY origin goes while in stasis. The camera anchor sits 0.65m above
; the body origin, so 0.3 here puts the eyes at 0.95 — just under the shell, looking out.
; Turned to face down the pod's length rather than up through the lid.
[node name="PodView" type="Marker3D" parent="."]
transform = Transform3D(-1, 0, 0, 0, 1, 0, 0, 0, -1, 0, 0.3, 0)
